#!/bin/bash

# Ensure the exit code of the pipe is the exit code of yamllint, not sed
set -o pipefail

# 1. Path to the real Mason binary
REAL_YAMLLINT="$HOME/.local/share/nvim/mason/bin/yamllint"

# 2. Extract arguments
ORIGINAL_PATH=""
for ((i=1; i<=$#; i++)); do
    if [[ "${!i}" == "--file-name" ]]; then
        j=$((i+1))
        ORIGINAL_PATH="${!j}"
        break
    fi
done

# If --file-name was not provided, use the last argument if it's a file
if [[ -z "$ORIGINAL_PATH" ]]; then
    for arg in "$@"; do
        if [[ -f "$arg" ]]; then
            ORIGINAL_PATH="$arg"
        fi
    done
fi

# 3. Create a unique temp directory for this run
TMP_DIR=$(mktemp -d)
# Trap to ensure cleanup of the temp directory
trap 'rm -rf "$TMP_DIR"' EXIT

# 4. Determine the target filename
if [[ -n "$ORIGINAL_PATH" ]]; then
    BASENAME=$(basename "$ORIGINAL_PATH")
    TEMP_FILE="$TMP_DIR/$BASENAME"
else
    TEMP_FILE="$TMP_DIR/buffer.yml"
fi

# 5. Capture stdin to the temp file
cat > "$TEMP_FILE"

# 6. Execute yamllint
# We don't pass --file-name because it's not supported by this binary.
# The filename itself in $TMP_DIR will trigger the correct config/ignores.
if [[ -n "$ORIGINAL_PATH" ]]; then
    # Replace the temp file path in the output with the original path
    "$REAL_YAMLLINT" --format parsable "$TEMP_FILE" | sed "s|$TEMP_FILE|$ORIGINAL_PATH|g"
else
    "$REAL_YAMLLINT" --format parsable "$TEMP_FILE"
fi

# 7. Final exit code
exit $?
