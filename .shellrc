## DEFAULT
set -o vi

## General
export PATH="$HOME/bin:$PATH"
export EDITOR=vim
export VISUAL=vim

## GO
export PATH="/usr/local/go/bin:$HOME/.cargo/bin:$PATH"

## Gemini
# For git push
export SANDBOX_FLAGS="-v $SSH_AUTH_SOCK:$SSH_AUTH_SOCK -e SSH_AUTH_SOCK=$SSH_AUTH_SOCK"
export GOOGLE_CLOUD_PROJECT="gen-lang-client-0947751397"
export OTLP_GOOGLE_CLOUD_PROJECT="$GOOGLE_CLOUD_PROJECT"
# Force the exporter to omit non-critical metadata
export GEMINI_TELEMETRY_LEVEL="ESSENTIAL"
# Stop the "TimeSeries failed" error from printing
export GEMINI_TELEMETRY_IGNORE_SHUTDOWN_ERRORS=true

# Pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - zsh)"
eval "$(pyenv virtualenv-init -)"

## SSH AGENT
SSH_ENV="$HOME/.ssh/environment"

function start_agent {
     echo "Initialising new SSH agent..."
     /usr/bin/ssh-agent | sed 's/^echo/#echo/' > "${SSH_ENV}"
     echo succeeded
     chmod 600 "${SSH_ENV}"
     . "${SSH_ENV}" > /dev/null
     /usr/bin/ssh-add;
}

# Source SSH settings, if applicable
if [ -f "${SSH_ENV}" ]; then
     . "${SSH_ENV}" > /dev/null
     #ps ${SSH_AGENT_PID} doesn't work under cywgin
     ps -ef | grep ${SSH_AGENT_PID} | grep ssh-agent$ > /dev/null || {
         rm -f ${SSH_ENV};
         start_agent;
     }
else
     start_agent;
fi

# make the nerdfont available to the chromebook terminal
FONT_SRV="${HOME}/bin/font-server.py"
if [ -x "${FONT_SRV}" ]; then
  (cd ${HOME}/.local/share/fonts; nohup "${FONT_SRV}" 127.0.0.1 8100 > /dev/null 2> /dev/null & )
fi

# esp open sdk
#if [ -d "/opt/xtensa-lx106-elf/bin" ]; then
#  export PATH=$PATH:/opt/xtensa-lx106-elf/bin
#fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# >>> talisman >>>
# Below environment variables should not be modified unless you know what you are doing
export TALISMAN_HOME=/Users/ray/.talisman/bin
alias talisman=$TALISMAN_HOME/talisman_darwin_arm64
export TALISMAN_INTERACTIVE=false
# # <<< talisman <<<
#
# Delta
export DELTA_FEATURES="diff-so-fancy"

# fzf
# Keep the fast file finding, but remove the extra UI clutter
export FZF_DEFAULT_COMMAND="rg --files --follow --hidden --glob '!.git'"
# Stripped down: No borders, no custom binds, no reverse layout
export FZF_DEFAULT_OPTS="--ansi --info=inline-right --layout=reverse --border=none \
--bind 'ctrl-j:down,ctrl-k:up,ctrl-u:preview-page-up,ctrl-d:preview-page-down'"
# Simple preview without the 100% height or complex paging
export FZF_CTRL_T_OPTS="--preview 'bat --color=always {}'"
